<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background"
    tools:context=".EditProfileActivity">

    <LinearLayout
        android:id="@+id/top_navigation"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginEnd="-260dp"
        android:layout_marginBottom="20dp"
        android:layout_toStartOf="@+id/editProfileTitle"
        android:background="#82CAFF"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/back_arrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/arrow" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Edit Profile"
            android:textColor="@color/black"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- Top Header (Optional) -->
    <TextView
        android:id="@+id/editProfileTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Profile"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginTop="100dp"
        android:layout_centerHorizontal="true" />

    <!-- Profile Picture -->
    <ImageView
        android:id="@+id/editProfileImage"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/mrbean"
        android:scaleType="centerCrop"
        android:layout_below="@id/editProfileTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:padding="5dp" />

    <View
        android:id="@+id/profileImage"
        android:layout_width="wrap_content"
        android:layout_height="12dp"
        android:layout_below="@id/editProfileImage"
        android:layout_centerHorizontal="true"/>

    <!-- Full Name Label -->
    <TextView
        android:id="@+id/labelName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Full Name"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:layout_marginTop="25dp"
        android:paddingStart="16dp"
        android:layout_below="@id/profileImage" />

    <EditText
        android:id="@+id/editName"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/labelName"
        android:hint="Enter your name"
        android:padding="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/rounded_corner"
        android:textSize="16sp" />

    <!-- Matric Label -->
    <TextView
        android:id="@+id/labelMatric"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Matric Number"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:layout_marginTop="20dp"
        android:paddingStart="16dp"
        android:layout_below="@id/editName" />

    <EditText
        android:id="@+id/editMatric"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/labelMatric"
        android:hint="Enter your matric number"
        android:padding="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/rounded_corner"
        android:textSize="16sp" />

    <!-- Save Button -->
    <Button
        android:id="@+id/saveButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_below="@id/editMatric"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="Save Changes"
        android:backgroundTint="#82CAFF"
        android:textColor="#000000"
        android:padding="16dp"
        android:layout_marginTop="32dp"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"/>

</RelativeLayout>

